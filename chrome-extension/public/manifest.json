{
  "manifest_version": 3,
  "name": "DeepCheck Guard",
  "version": "1.0.0",
  "description": "Autonomous real-time shield against AI-generated phishing and deepfake media.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:3001/*",
    "http://localhost:3001/*",
    "http://127.0.0.1:3001/*",
    "http://127.0.0.1:8080/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["hud.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["hud.css"],
      "matches": ["<all_urls>"]
    }
  ]
}